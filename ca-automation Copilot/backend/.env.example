# Backend Server
PORT=4000
PYTHON_BIN=python3

# Email — sender is fixed to automation.atwork69@gmail.com
# Only the App Password is required.
#
# To generate a Gmail App Password:
#   1. Go to https://myaccount.google.com/security
#   2. Enable 2-Step Verification
#   3. Go to https://myaccount.google.com/apppasswords
#   4. Create an App Password for "Mail"
#   5. Paste the 16-character password below (no spaces)
SMTP_PASS=your-16-char-gmail-app-password

# Optional overrides (defaults already set in code)
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587

# Testing — redirect ALL outgoing emails to one inbox (remove when going live)
# TEST_EMAIL=your-test-inbox@yahoo.com
