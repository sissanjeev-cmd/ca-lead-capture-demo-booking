{
  "name": "taskflow-desktop",
  "version": "1.0.0",
  "description": "TaskFlow — always-on-top desktop todo & reminder widget for macOS",
  "main": "src/main.js",
  "scripts": {
    "start": "unset ELECTRON_RUN_AS_NODE && electron .",
    "dev": "unset ELECTRON_RUN_AS_NODE && electron . --dev",
    "dist": "electron-builder --mac dmg"
  },
  "build": {
    "appId": "com.taskflow.desktop",
    "productName": "TaskFlow",
    "copyright": "Copyright © 2025 TaskFlow",
    "mac": {
      "category": "public.app-category.productivity",
      "identity": null,
      "icon": "build/icon.png",
      "target": [
        { "target": "dmg", "arch": ["universal"] }
      ]
    },
    "dmg": {
      "title": "Install TaskFlow",
      "backgroundColor": "#f0eeff",
      "window": { "width": 540, "height": 380 },
      "contents": [
        { "x": 150, "y": 180, "type": "file" },
        { "x": 390, "y": 180, "type": "link", "path": "/Applications" }
      ]
    },
    "files": [
      "src/**/*",
      "package.json"
    ],
    "asar": true
  },
  "devDependencies": {
    "electron": "^28.0.0",
    "electron-builder": "^26.8.1"
  },
  "author": "TaskFlow",
  "license": "MIT"
}
